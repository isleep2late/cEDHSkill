# Environment variables — keep real configs LOCAL-ONLY, never on GitHub.
# Ignores .env and backup copies (.env-GONE / .env-REALONE / .env-TESTSERVER), which
# hold real Discord bot tokens. The placeholder template .env.example IS tracked, so
# anyone can copy it to .env and set up their own server.
.env*
!.env.example

# Dependencies
node_modules/

# Build output
dist/

# Database
data/
*.db
*.db-shm
*.db-wal

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Backup files
*.backup
backups/

# Desktop helper buttons (live in ~/Desktop/cEDHSkill_buttons/; ignored if ever copied into the repo)
Push_To_GitHub.sh
Pull_From_GitHub.sh
